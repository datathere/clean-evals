# clean-evals configuration.
#
# 1. Copy this file to .env
# 2. Add at least one provider API key
# 3. Start the app with: clean-evals serve
#
# Loaded automatically on startup. .env is gitignored.
# Optional settings have working defaults.

# ---------------------------------------------------------------------------
# Provider API keys
# ---------------------------------------------------------------------------
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
# https://aistudio.google.com/apikey
GOOGLE_API_KEY=
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ---------------------------------------------------------------------------
# Optional
# ---------------------------------------------------------------------------
# Database. Default: sqlite under ./clean-evals-data/. For a shared instance:
#   mysql+pymysql://user:pass@localhost:3306/clean_evals
#   postgresql+psycopg2://user:pass@localhost:5432/clean_evals
CLEAN_EVALS_DATABASE_URL=

# Report output folder. Default: ./clean-evals-data/artifacts
CLEAN_EVALS_ARTIFACT_DIR=

# Refuse to start a new run once today's persisted spend meets this amount
# (USD). Best-effort: only persisted runs count (web, scheduled, and CLI runs
# with --persist), and in-flight calls are never interrupted. Always verify
# actual spend in your provider's billing console.
CLEAN_EVALS_DAILY_COST_LIMIT_USD=

# Required for scheduled runs only (clean-evals worker / beat).
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Log level for clean-evals serve. Default: INFO
CLEAN_EVALS_LOG_LEVEL=

# Pricing overrides file. Default: ./clean-evals-data/pricing.yml
# (edited from the Models page; set this to relocate it)
CLEAN_EVALS_PRICING_FILE=

# Excluded-models file. Default: ./clean-evals-data/excluded-models.yml
CLEAN_EVALS_EXCLUDED_MODELS_FILE=

# Set to 1 to silence the warning printed when serve binds to a
# non-loopback address. clean-evals has no auth; know what you are doing.
CLEAN_EVALS_ACK_REMOTE_BIND=

# docker-compose only: which database profile to start. The default starts
# MySQL; set to `postgres` (and point CLEAN_EVALS_DATABASE_URL at it) for
# Postgres.
COMPOSE_PROFILES=default
