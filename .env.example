# clean-evals configuration.
#
# 1. Copy this file to .env
# 2. Add at least one provider API key
# 3. Start the app with: clean-evals serve
#
# Loaded automatically on startup. .env is gitignored.
# Optional settings have working defaults.

# ---------------------------------------------------------------------------
# Provider API keys
# ---------------------------------------------------------------------------
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
# https://aistudio.google.com/apikey
GOOGLE_API_KEY=
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Local models via any OpenAI-compatible server (Ollama, LM Studio,
# llama.cpp, vLLM). Set the base URL to enable; model ids then use the
# local/ prefix, e.g. --models local/llama3.2. Default when unset:
# http://localhost:11434/v1 (Ollama).
CLEAN_EVALS_LOCAL_BASE_URL=
# Optional bearer token for servers that require one (vLLM --api-key).
CLEAN_EVALS_LOCAL_API_KEY=

# ---------------------------------------------------------------------------
# Optional
# ---------------------------------------------------------------------------
# Database. Default: sqlite under ./clean-evals-data/. For a shared instance:
#   mysql+pymysql://user:pass@localhost:3306/clean_evals
#   postgresql+psycopg2://user:pass@localhost:5432/clean_evals
CLEAN_EVALS_DATABASE_URL=

# Report output folder. Default: ./clean-evals-data/artifacts
CLEAN_EVALS_ARTIFACT_DIR=

# Refuse to start a new run once today's persisted spend meets this amount
# (USD). Best-effort: only persisted runs count (web, scheduled, and CLI runs
# with --persist), and in-flight calls are never interrupted. Always verify
# actual spend in your provider's billing console.
CLEAN_EVALS_DAILY_COST_LIMIT_USD=

# Required for scheduled runs only (clean-evals worker / beat).
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Log level for clean-evals serve. Default: INFO
CLEAN_EVALS_LOG_LEVEL=

# Pricing overrides file. Default: ./clean-evals-data/pricing.yml
# (edited from the Models page; set this to relocate it)
CLEAN_EVALS_PRICING_FILE=

# Excluded-models file. Default: ./clean-evals-data/excluded-models.yml
CLEAN_EVALS_EXCLUDED_MODELS_FILE=

# Set to 1 to silence the warning printed when serve binds to a
# non-loopback address. clean-evals has no auth; know what you are doing.
CLEAN_EVALS_ACK_REMOTE_BIND=

# ---------------------------------------------------------------------------
# Telemetry (docs: guides/telemetry.md)
# ---------------------------------------------------------------------------
# Bearer token for POST /api/v1/telemetry/interactions. Unset = the route
# answers 404. The token protects that route ONLY; the rest of the app
# remains unauthenticated and must stay unreachable from any untrusted
# network.
CLEAN_EVALS_INGEST_TOKEN=

# Model that labels transcript follow-ups (one call per transcript).
# Default: claude-haiku-4-5-20251001
CLEAN_EVALS_TELEMETRY_CLASSIFIER_MODEL=

# Classifier spend ceiling per UTC day, USD. Default: 5.0. Best-effort;
# interactions over budget stay pending and are retried the next pass.
CLEAN_EVALS_TELEMETRY_DAILY_COST_LIMIT_USD=

# Entry-point name (group clean_evals.telemetry_scrubbers) of a scrubber
# run on every envelope BEFORE it is stored. Unset = envelopes stored raw.
CLEAN_EVALS_TELEMETRY_SCRUBBER=

# Set to 1 to enable the auto-lock lane: exchanges whose explicit accept,
# implicit rating (>= 4), and calibrated judge all concur are promoted and
# locked without review, minus a spot-check sample. The lane self-disables
# when the human overturn rate on spot checks crosses the threshold.
CLEAN_EVALS_TELEMETRY_AUTOLOCK=
# Minimum judge-calibration kappa for the lane to operate. Default: 0.6
CLEAN_EVALS_TELEMETRY_AUTOLOCK_KAPPA=
# Fraction of auto-locked exchanges routed to human spot-check. Default: 0.10
CLEAN_EVALS_TELEMETRY_SPOTCHECK_RATE=
# Overturn rate at which the lane self-disables (over >= 5 resolved
# checks). Default: 0.2
CLEAN_EVALS_TELEMETRY_OVERTURN_DISABLE=

# Fraction (0-1) of derived exchanges scored by the dataset's calibrated
# judge for monitoring. Default: 0 (off — judge sampling spends money, and
# its spend is NOT metered by the telemetry ceiling; the rate bounds the
# call count).
CLEAN_EVALS_TELEMETRY_JUDGE_SAMPLE_RATE=

# docker-compose only: which database profile to start. The default starts
# MySQL; set to `postgres` (and point CLEAN_EVALS_DATABASE_URL at it) for
# Postgres.
COMPOSE_PROFILES=default
